# Core
# DEBUG_MODE enables developer conveniences (e.g. HSTS off, verbose errors).
# Keep this FALSE in production. Never combine with AUTH_MODE=oauth.
DEBUG_MODE=false
APP_NAME=API Keys
# Optional URL path prefix the app is served under. Set when the app sits
# behind a reverse proxy path mapping such as mydomain.com/start -> this
# container. Leave blank to serve from the site root. Example: /start
ROOT_PATH=

# LiteLLM Proxy
LITELLM_BASE_URL=http://localhost:4000
LITELLM_ADMIN_KEY=sk-your-admin-key
# Timeouts (seconds) for outbound LiteLLM calls
LITELLM_CONNECT_TIMEOUT=2.0
LITELLM_READ_TIMEOUT=10.0

# Auth
# AUTH_MODE selects how users are authenticated.
#   - "proxy": trust a header set by a reverse proxy (default)
#   - "oauth": run a standard OAuth 2.0 / OIDC authorization code flow
AUTH_MODE=proxy

# --- Reverse proxy mode (AUTH_MODE=proxy) ---
AUTH_USER_HEADER=X-User-Email
TEST_USER=test@test.com
PROXY_SECRET_HEADER=X-Proxy-Secret
# REQUIRED in production: the reverse proxy must send this shared secret
# so direct traffic bypassing the proxy cannot spoof the user header.
PROXY_SECRET=
# Defaults to TRUE. Only disable for local development behind an explicit
# DEBUG_MODE=true or ALLOW_INSECURE_STARTUP=true escape hatch.
FEATURE_PROXY_SECRET_ENABLED=true
# Strip @domain from the authenticated username (e.g. alice@corp.com -> alice)
STRIP_USER_DOMAIN=false
# Dev-only: fall back to TEST_USER when no auth header is present. Never
# enable in production. Also requires DEBUG_MODE=true.
ALLOW_TEST_USER=false
# Dev-only escape hatch to start proxy mode without a shared secret.
ALLOW_INSECURE_STARTUP=false

# --- OAuth mode (AUTH_MODE=oauth) ---
# Example (Google):
#   OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
#   OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
#   OAUTH_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
# Example (GitHub):
#   OAUTH_AUTHORIZE_URL=https://github.com/login/oauth/authorize
#   OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
#   OAUTH_USERINFO_URL=https://api.github.com/user
#   OAUTH_SCOPES=read:user user:email
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_AUTHORIZE_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=
OAUTH_SCOPES=openid email profile
# Full callback URL registered with your provider
OAUTH_REDIRECT_URL=http://localhost:8000/api/auth/callback
# Field name in the userinfo JSON containing the user's email
OAUTH_EMAIL_FIELD=email
# Secret used to sign the session cookie (required when AUTH_MODE=oauth).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
SESSION_COOKIE_NAME=signup_session
SESSION_MAX_AGE=604800
# Idle timeout: session evicted if unused for this many seconds (default 1 day).
SESSION_IDLE_TIMEOUT=86400
# Require HTTPS for the session cookie. Set to false when TLS is terminated
# upstream (e.g. a Kubernetes ingress) and the app only sees HTTP internally.
# NOTE: when DEBUG_MODE=true this is silently downgraded to false and a
# warning is logged.
SESSION_COOKIE_SECURE=true

# Rate limits (in-memory, fixed window)
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_KEY_CREATE_PER_HOUR=30
RATE_LIMIT_LOGIN_PER_MINUTE=10

# Key policy
# Maximum number of active (non-expired, non-blocked) keys a user may hold.
# Leave blank / unset for no limit.
MAX_ACTIVE_KEYS_PER_USER=
# Comma-separated list of metadata fields to require on each key
# (e.g. project,task_number). These will be collected from the UI and
# stored with the virtual key.
REQUIRED_KEY_METADATA=
