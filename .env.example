# Core
DEBUG_MODE=true
APP_NAME=API Keys

# LiteLLM Proxy
LITELLM_BASE_URL=http://localhost:4000
LITELLM_ADMIN_KEY=sk-your-admin-key

# Auth
AUTH_USER_HEADER=X-User-Email
TEST_USER=test@test.com
PROXY_SECRET_HEADER=X-Proxy-Secret
PROXY_SECRET=
FEATURE_PROXY_SECRET_ENABLED=false
# Strip @domain from the authenticated username (e.g. alice@corp.com -> alice)
STRIP_USER_DOMAIN=false

# Key policy
# Maximum number of active (non-expired, non-blocked) keys a user may hold.
# Leave blank / unset for no limit.
MAX_ACTIVE_KEYS_PER_USER=
# Comma-separated list of metadata fields to require on each key
# (e.g. project,task_number). These will be collected from the UI and
# stored with the virtual key.
REQUIRED_KEY_METADATA=
